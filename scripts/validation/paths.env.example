# Copy to .local/paths.env (gitignored; see .gitignore) and fill in agent paths.
# Nothing under .local/ is pushed to this repository.
#
# Canonical smoke target (pin — do not use floating main):
#   https://github.com/juice-shop/juice-shop/releases/tag/v20.0.0
#   commit f356a09207c7a9550eb6fc4c3945e081922cf998
#   git clone https://github.com/juice-shop/juice-shop.git /path/to/juice-shop
#   cd /path/to/juice-shop && git checkout f356a09207c7a9550eb6fc4c3945e081922cf998
#
# Linux agent example layout:
#
#   ENDORLABS_BUILDKITE_PLUGIN_REF="file:///var/lib/buildkite-agent/plugins/endorlabs-buildkite-plugin"
#   VALIDATION_REPO_JUICE_SHOP="/var/lib/buildkite-agent/git/juice-shop"
#   (optional extended matrix only: DEFECTDOJO, AGENT, MONGO, SPRING_BOOT)
#
# ENDOR_NAMESPACE is your Endor tenant namespace (non-secret identifier).
# API credentials must be supplied as pipeline/agent env vars ENDOR_API_KEY / ENDOR_API_SECRET
# (see docs/maintainers/validation.md). Local-smoke scan JSON goes in .local/scans/.

ENDORLABS_BUILDKITE_PLUGIN_REF="file:///PATH/TO/endorlabs-buildkite-plugin"
VALIDATION_REPO_DEFECTDOJO="/PATH/TO/django-DefectDojo"
VALIDATION_REPO_AGENT="/PATH/TO/agent"
VALIDATION_REPO_MONGO="/PATH/TO/mongo"
VALIDATION_REPO_SPRING_BOOT="/PATH/TO/spring-boot"
VALIDATION_REPO_JUICE_SHOP="/PATH/TO/juice-shop"  # checkout at f356a09207c7a9550eb6fc4c3945e081922cf998 (v20.0.0)
ENDOR_NAMESPACE="your-namespace"
