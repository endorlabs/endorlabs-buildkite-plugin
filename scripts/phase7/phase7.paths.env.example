# Copy to phase7.paths.env (gitignored) and fill in paths visible on Buildkite agents.
# Linux agent example layout:
#
#   ENDORLABS_BUILDKITE_PLUGIN_REF="file:///var/lib/buildkite-agent/plugins/endorlabs-buildkite-plugin"
#   PHASE7_REPO_DEFECTDOJO="/var/lib/buildkite-agent/git/django-DefectDojo"
#   PHASE7_REPO_AGENT="/var/lib/buildkite-agent/git/agent"
#   PHASE7_REPO_MONGO="/var/lib/buildkite-agent/git/mongo"
#   PHASE7_REPO_SPRING_BOOT="/var/lib/buildkite-agent/git/spring-boot"
#   PHASE7_REPO_JUICE_SHOP="/var/lib/buildkite-agent/git/juice-shop"
#
# ENDOR_NAMESPACE is your Endor tenant namespace (non-secret identifier).
# API credentials must be supplied as pipeline/agent env vars ENDOR_API_KEY / ENDOR_API_SECRET
# (see docs/phase7-validation.md).

ENDORLABS_BUILDKITE_PLUGIN_REF="file:///PATH/TO/endorlabs-buildkite-plugin"
PHASE7_REPO_DEFECTDOJO="/PATH/TO/django-DefectDojo"
PHASE7_REPO_AGENT="/PATH/TO/agent"
PHASE7_REPO_MONGO="/PATH/TO/mongo"
PHASE7_REPO_SPRING_BOOT="/PATH/TO/spring-boot"
PHASE7_REPO_JUICE_SHOP="/PATH/TO/juice-shop"
ENDOR_NAMESPACE="your-namespace"
